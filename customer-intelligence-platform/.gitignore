# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Virtual environments
.env
.env.local
.venv/
venv/
env/
ENV/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Jupyter
.ipynb_checkpoints/

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# Data — keep only sample_data.csv tracked
data/raw/
data/processed/
data/*.xlsx
data/*.zip
!data/sample_data.csv

# Trained models (regenerated by scripts/train_all.py)
models/*.pkl
models/*.joblib
models/*.h5
models/*.json
models/*.onnx

# Logs
*.log

# Test scratch files
.tmp_test_*

# Streamlit cache
.streamlit/cache/

# Generated figures (keep the folders via .gitkeep, ignore contents)
reports/figures/**/*.png
reports/figures/**/*.jpg
reports/figures/**/*.svg
!reports/figures/**/.gitkeep

